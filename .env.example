# Supabase - used by the Vite app (browser)
# Get these from: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Klaviyo (server-side, Supabase Edge Functions). Use live TSL account keys in Supabase secrets.
# Private API key (Klaviyo → API keys). Also accepts legacy name KLAVIYO_PRIVATE_API_KEY.
KLAVIYO_API_KEY=your_klaviyo_private_api_key_here
# API revision header (e.g. 2025-10-15)
KLAVIYO_API_REVISION=2025-10-15
# Public company id (browser Klaviyo snippet / campaigns); not required for server Events API
KLAVIYO_COMPANY_ID=your_klaviyo_company_id_here
KLAVIYO_PRIVATE_API_KEY=

# Customer app base URL (email confirmation + sign-up redirect). Production: https://portal.thesamplelab.app
CUSTOMER_APP_URL=https://portal.thesamplelab.app
