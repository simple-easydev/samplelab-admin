# Supabase - used by the Vite app (browser)
# Get these from: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Klaviyo (server-side, Supabase Edge Functions)
# Create this in Klaviyo dashboard → API Keys → Private API Key
# Configure it in Supabase Function secrets (do not expose to browser).
KLAVIYO_PRIVATE_API_KEY=your_klaviyo_private_api_key_here

# Optional: credits-low threshold (server-side)
CREDITS_LOW_THRESHOLD=3
